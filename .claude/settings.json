{
  "permissions": {
    "allow": [
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(find:*)",
      "Bash(which:*)",
      "Bash(pwd)",
      "Bash(echo:*)",
      "Bash(printf:*)",
      "Bash(test:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(jq:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git remote:*)",
      "Bash(git rev-parse:*)",
      "Bash(git ls-files:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh issue view:*)",
      "Bash(gh issue list:*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)",
      "Bash(gh workflow list:*)",
      "Bash(gh workflow view:*)",
      "Bash(npm run lint:*)",
      "Bash(npm run type-check:*)",
      "Bash(npm test:*)",
      "Bash(npm view:*)",
      "Bash(npm list:*)",
      "Bash(./node_modules/.bin/tsc:*)",
      "Bash(./node_modules/.bin/eslint:*)",
      "Bash(./node_modules/.bin/prettier:*)",
      "Bash(./node_modules/.bin/vitest:*)",
      "Bash(./node_modules/.bin/playwright:*)",
      "Bash(npx tsc:*)",
      "Bash(npx prettier --check:*)",
      "Bash(python3 scripts/detect_hidden_bugs.py:*)",
      "Bash(python3 scripts/*.py:*)",
      "Bash(python3 -c:*)",
      "Bash(python3 -m json.tool:*)",
      "Bash(node -e:*)",
      "Bash(node --version)",
      "Bash(npm --version)",
      "Bash(python3 --version)",
      "Bash(date:*)",
      "Bash(uname:*)",
      "Bash(env)",
      "Read(//Users/toshikiterasawa/Claude/**)",
      "Edit(//Users/toshikiterasawa/Claude/**)",
      "Write(//Users/toshikiterasawa/Claude/**)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(sudo:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -f:*)",
      "Bash(git branch -D:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "cd ~/Claude/bjj-app && ./node_modules/.bin/tsc --noEmit 2>&1 | tail -5; python3 scripts/detect_hidden_bugs.py --ci 2>&1 | grep -E '(CRITICAL|WARNING|合計)'"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "if echo \"$TOOL_INPUT\" | grep -qE '\\bgit\\s+(add|commit|push|reset)\\b'; then echo 'BLOCKED: git コマンドは禁止。CLAUDE_COMMIT_MSG に書いてください。' && exit 2; fi"
          },
          {
            "type": "command",
            "command": "if echo \"$TOOL_INPUT\" | grep -qE '\\bsed\\s+-i\\b|\\bawk\\b.*>.*\\.(ts|tsx|json|md|html)'; then echo 'BLOCKED: sed -i / awk によるファイル編集は文字化けの原因。Python/Node.js + UTF-8 を使ってください。' && exit 2; fi"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd ~/Claude/bjj-app && if [ -n \"$(find . -name '*.ts' -o -name '*.tsx' -o -name '*.json' -newer .git/HEAD -not -path './node_modules/*' -not -path './.next/*' 2>/dev/null | head -1)\" ] && [ ! -f .git/CLAUDE_COMMIT_MSG ]; then echo '⚠️ 未コミットの変更があります。CLAUDE_COMMIT_MSG への書き込みを忘れていませんか？'; fi"
          }
        ]
      }
    ]
  }
}

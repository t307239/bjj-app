# Supabase (必須)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# サイトURL (Vercelでは本番URLを設定)
# ローカル: http://localhost:3000
# 本番: https://bjj-app.net
NEXT_PUBLIC_APP_URL=https://bjj-app.net
NEXT_PUBLIC_SITE_URL=https://bjj-app.net

# -----------------------------------------------------------
# Stripe B2C (Pro個人プラン)
# -----------------------------------------------------------
# APIキー: Stripe Dashboard > Developers > API keys
STRIPE_SECRET_KEY=sk_live_...
# Webhookシークレット: Stripe Dashboard > Developers > Webhooks > エンドポイント選択 > Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# Price ID: Stripe Dashboard > Products > BJJ App Pro > Prices > price_xxx をコピー
# Payment Linkより優先される（14日間無料トライアルが付く）
STRIPE_B2C_PRICE_ID=price_...
STRIPE_ANNUAL_PRICE_ID=price_...

# Payment Link (Price IDがない場合のフォールバック / トライアルなし)
# Stripe Dashboard > Payment Links > リンクを作成
NEXT_PUBLIC_STRIPE_PAYMENT_LINK=https://buy.stripe.com/...
NEXT_PUBLIC_STRIPE_ANNUAL_LINK=https://buy.stripe.com/...

# Customer Portal URL: Stripe Dashboard > Customer portal > 「ポータルリンクをコピー」
NEXT_PUBLIC_STRIPE_CUSTOMER_PORTAL_URL=https://billing.stripe.com/p/login/...

# -----------------------------------------------------------
# Stripe B2B (Gym道場プラン — $79.99/mo)
# -----------------------------------------------------------
# Price ID: Stripe Dashboard > Products > BJJ App Gym > Prices > price_xxx
# Price IDが設定されていればCheckout API経由（完全自動化）
# 未設定の場合はPayment Linkにフォールバック（手動フラグ更新が必要）
STRIPE_GYM_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_GYM_PAYMENT_LINK=https://buy.stripe.com/...

# -----------------------------------------------------------
# Web Push Notifications / VAPID
# -----------------------------------------------------------
# キー生成: npx web-push generate-vapid-keys
# 一度生成したら変更禁止（変更すると既存の全サブスクリプションが無効化される）
#
# Vercel設定手順:
#   1. Vercel Dashboard > bjj-app > Settings > Environment Variables
#   2. 以下の3変数を Production / Preview / Development 全環境に追加
#   3. Redeploy（変数追加後にデプロイし直す必要あり）
#
NEXT_PUBLIC_VAPID_PUBLIC_KEY=BLGjHdlO0ujKWIaNhtg89MXMV34aJjmUf_ZoUGvGTJoeEzjIgs8cT68XGjpZJg0ssc59VR8oDBHRlh0x8WaIDbQ
VAPID_PRIVATE_KEY=your-private-key
VAPID_SUBJECT=mailto:307239t777@gmail.com

# 管理者メール（push/send APIのAdmin認証用）
ADMIN_EMAIL=307239t777@gmail.com

# Push送信APIのシークレット（cron/automation用オプション）
PUSH_SEND_SECRET=your-random-secret-here

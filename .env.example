# Supabase (必須)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# サイトURL (Vercelでは本番URLを設定)
# ローカル: http://localhost:3000
# 本番: https://bjj-app.net
NEXT_PUBLIC_APP_URL=https://bjj-app.net
NEXT_PUBLIC_SITE_URL=https://bjj-app.net

# -----------------------------------------------------------
# Stripe B2C (Pro個人プラン)
# -----------------------------------------------------------
# APIキー: Stripe Dashboard > Developers > API keys
STRIPE_SECRET_KEY=sk_live_...
# Webhookシークレット: Stripe Dashboard > Developers > Webhooks > エンドポイント選択 > Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# Price ID: Stripe Dashboard > Products > BJJ App Pro > Prices > price_xxx をコピー
# Payment Linkより優先される（14日間無料トライアルが付く）
STRIPE_B2C_PRICE_ID=price_...
STRIPE_ANNUAL_PRICE_ID=price_...

# Payment Link (Price IDがない場合のフォールバック / トライアルなし)
# Stripe Dashboard > Payment Links > リンクを作成
NEXT_PUBLIC_STRIPE_PAYMENT_LINK=https://buy.stripe.com/...
NEXT_PUBLIC_STRIPE_ANNUAL_LINK=https://buy.stripe.com/...

# Customer Portal URL: Stripe Dashboard > Customer portal > 「ポータルリンクをコピー」
NEXT_PUBLIC_STRIPE_CUSTOMER_PORTAL_URL=https://billing.stripe.com/p/login/...

# -----------------------------------------------------------
# Stripe B2B (Gym道場プラン — $49/mo)
# -----------------------------------------------------------
NEXT_PUBLIC_STRIPE_GYM_PAYMENT_LINK=https://buy.stripe.com/...

# ROBUST ジム会員管理システム — 環境変数テンプレート
# 本番: Vercel Dashboard > Environment Variables に設定
# ローカル: .env.local にコピーして値を埋める

# ── Supabase gym-member-hub プロジェクト ──────────────────────
NEXT_PUBLIC_ROBUST_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_ROBUST_SUPABASE_ANON_KEY=eyJ...
ROBUST_SUPABASE_SERVICE_ROLE_KEY=eyJ...   # サーバーサイド専用

# ── ROBUST 専用 Stripe（bjj-app とは別アカウント）──────────────
ROBUST_STRIPE_SECRET_KEY=sk_live_...
ROBUST_STRIPE_WEBHOOK_SECRET=whsec_...   # stripe listen --forward-to localhost:3000/api/gym/webhook

# Stripe Price IDs（Stripe Dashboard で作成後に設定）
STRIPE_ROBUST_PRICE_FULLTIME_MALE=price_...    # ¥12,000/月
STRIPE_ROBUST_PRICE_FULLTIME_FEMALE=price_...  # ¥10,000/月
STRIPE_ROBUST_PRICE_TWICE_MALE=price_...       # ¥10,000/月
STRIPE_ROBUST_PRICE_TWICE_KIDS=price_...       # ¥7,000/月
STRIPE_ROBUST_PRICE_DROP_IN=price_...          # ¥2,000/回

# ── ジム設定 ──────────────────────────────────────────────────
NEXT_PUBLIC_ROBUST_GYM_ID=           # gyms テーブルの id（初回 INSERT 後に設定）
NEXT_PUBLIC_SITE_URL=https://app.robust-bjj.jp

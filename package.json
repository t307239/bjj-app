{
  "name": "bjj-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "check-links": "node scripts/check-links.mjs",
    "license:audit": "node scripts/license-audit.mjs",
    "license:audit:full": "node scripts/license-audit.mjs --full",
    "license:audit:json": "node scripts/license-audit.mjs --json",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "analyze": "ANALYZE=true next build",
    "check:env": "node scripts/check-env.mjs",
    "check:backup": "node scripts/verify-backup.mjs",
    "check:smoke": "node scripts/smoke-test.mjs",
    "check:bundle": "node scripts/bundle-size-check.mjs",
    "check:images": "node scripts/image-audit.mjs",
    "check:exports": "node scripts/check-unused-exports.mjs",
    "check:types-strict": "node scripts/check-types-strict.mjs",
    "check:all": "npm run lint && tsc --noEmit && npm run test && python3 scripts/detect_hidden_bugs.py --fix-hint",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix --max-warnings 0"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@sentry/nextjs": "^8.55.2",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.105.1",
    "@tailwindcss/typography": "^0.5.19",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "@xyflow/react": "^12.10.2",
    "cheerio": "^1.2.0",
    "dagre": "^0.8.5",
    "next": "^15.5.15",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "stripe": "^17.7.0",
    "web-push": "^3.6.7",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.4",
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.19.17",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/web-push": "^3.6.4",
    "@vitest/coverage-v8": "^4.1.5",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.5.15",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.13",
    "prettier": "^3.8.3",
    "tailwindcss": "^3.4.19",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
